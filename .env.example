# Copy this file to ".env.local" for local development, and set the same
# variables in your host dashboard (Vercel → Settings → Environment Variables)
# for production. NEVER commit real values — .env.local is gitignored.

# --- Gemini (server-only; powers model responses) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash)
GEMINI_MODEL=

# --- Supabase (auth + persistence) ---
# These two are PUBLIC (safe for the browser). From Supabase →
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
